---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getTranslations } from "../../i18n/translations";
import { ChevronRight } from "lucide-astro";

const locale = "en";
const t = getTranslations(locale);

const projectMilestones = [
  {
    title: "Group Formation",
    date: "2025-04-01",
    description:
      "Form teams of 2-3 students and register them on the virtual campus",
  },
  {
    title: "Project Proposal",
    date: "2025-04-15",
    description:
      "Initial proposal presentation including objectives, scope, and methodology",
  },
  {
    title: "First Submission",
    date: "2025-05-15",
    description:
      "Project progress with initial implementation and preliminary results",
  },
  {
    title: "Final Submission",
    date: "2025-06-15",
    description:
      "Final project presentation, documented code, and results analysis",
  },
] as const;

const projectTracks = [
  {
    title: "Scientific Computing",
    description:
      "Parallel implementation of numerical algorithms and scientific simulations",
    examples: [
      "N-body simulation",
      "Computational fluid dynamics",
      "Finite element methods",
      "Differential equation solving",
    ],
  },
  {
    title: "Data Processing",
    description:
      "Parallel analysis of large datasets and massive-scale processing",
    examples: [
      "Medical image processing",
      "Social network analysis",
      "Massive data clustering",
      "Signal processing",
    ],
  },
  {
    title: "Optimization",
    description:
      "Parallel algorithms for optimization and search problems",
    examples: [
      "Parallel genetic algorithms",
      "Particle swarm optimization",
      "Distributed deep learning",
      "Pattern search",
    ],
  },
] as const;

const guidelines = [
  {
    title: "Objectives",
    content: `The final project aims to apply the parallel programming concepts and techniques
      learned during the course to a real-world problem.
      Teams must demonstrate effective use of at least two parallel
      programming paradigms (OpenMP, MPI, CUDA) and perform a performance analysis.`,
  },
  {
    title: t.project.requirements,
    items: [
      "Teams of 2-3 students",
      "Use of at least two parallel programming paradigms",
      "Performance and scalability analysis",
      "Complete project documentation",
      "Source code on GitHub",
      "Final presentation",
    ],
  },
  {
    title: "Grading",
    items: [
      "Initial proposal (10%)",
      "Midterm progress (20%)",
      "Code and documentation (40%)",
      "Final presentation (30%)",
    ],
  },
  {
    title: "Deliverables",
    items: [
      "Proposal document (PDF)",
      "GitHub code repository",
      "Final technical report (PDF)",
      "Presentation (PDF/PPT)",
      "Demo video (5 min)",
    ],
  },
];
---

<BaseLayout title={t.project.title} locale={locale}>
  <div class="prose dark:prose-invert max-w-none">
    <h1 class="text-2xl font-semibold mb-6">{t.project.title}</h1>

    <div class="">
      <div class="flex gap-4 space-y-6">
        <section class="mb-0">
          {
            guidelines.map((section) => (
              <div class="mb-6 last:mb-0">
                <h2 class="text-lg font-medium mt-0 mb-3">{section.title}</h2>
                {section.content && (
                  <p class="text-zinc-600 dark:text-zinc-300 text-sm">
                    {section.content}
                  </p>
                )}
                {section.items && (
                  <ul class="mt-3 space-y-2">
                    {section.items.map((item) => (
                      <li class="flex gap-2 text-sm">
                        <ChevronRight class="w-4 h-4 text-zinc-400 shrink-0" />
                        <span>{item}</span>
                      </li>
                    ))}
                  </ul>
                )}
              </div>
            ))
          }
        </section>
        <aside class="space-y-6">
          <section class="p-6">
            <h2 class="text-lg font-medium mt-0 mb-4">{t.project.timeline}</h2>
            <div class="space-y-4">
              {
                projectMilestones.map((milestone) => (
                  <div class="border-l-2 border-zinc-200 dark:border-zinc-700 pl-4">
                    <h3 class="text-base font-medium mt-0 mb-1">
                      {milestone.title}
                    </h3>
                    <time class="text-sm text-zinc-500">
                      {new Date(milestone.date).toLocaleDateString("en-US", {
                        month: "long",
                        day: "numeric",
                      })}
                    </time>
                    <p class="text-sm text-zinc-600 dark:text-zinc-300 mt-1">
                      {milestone.description}
                    </p>
                  </div>
                ))
              }
            </div>
          </section>
        </aside>
      </div>

      <section class="p-6">
        <h2 class="text-lg font-medium mt-0 mb-4">{t.project.projectTracks}</h2>
        <div class="grid gap-4 sm:grid-cols-2">
          {
            projectTracks.map((track) => (
              <div class="bg-white dark:bg-zinc-800/50 border border-zinc-200 dark:border-zinc-700 rounded p-4">
                <h3 class="text-base font-medium mt-0 mb-2">{track.title}</h3>
                <p class="text-sm text-zinc-600 dark:text-zinc-300 mb-3">
                  {track.description}
                </p>
                <ul class="space-y-1 mb-0">
                  {track.examples.map((example) => (
                    <li class="text-sm flex items-center gap-2">
                      <ChevronRight class="w-3.5 h-3.5 text-zinc-400" />
                      {example}
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>
      </section>
    </div>
  </div>
</BaseLayout>
