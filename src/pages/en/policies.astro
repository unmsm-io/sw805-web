---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getTranslations } from "../../i18n/translations";
import { Shield, Bot, Clock, UserCheck, Heart } from "lucide-astro";

const locale = "en";
const t = getTranslations(locale);
---

<BaseLayout title={t.policies.title} locale={locale}>
  <div class="prose dark:prose-invert max-w-none">
    <h1 class="text-2xl font-semibold mb-6">{t.policies.title}</h1>

    <div class="space-y-8">
      <section>
        <div class="flex items-center gap-3 mb-4">
          <Shield class="w-5 h-5 text-zinc-500 dark:text-zinc-400 flex-shrink-0" />
          <h2 class="text-lg font-medium mt-0 mb-0">
            {t.policies.academicIntegrity}
          </h2>
        </div>
        <div
          class="bg-white dark:bg-zinc-800/50 border border-zinc-200 dark:border-zinc-700 rounded p-5 space-y-3"
        >
          <p class="text-sm text-zinc-600 dark:text-zinc-300 mt-0 mb-0">
            {t.policies.academicIntegrityText}
          </p>
          <p class="text-sm font-medium mt-0 mb-1">
            {t.policies.plagiarismInCode}
          </p>
          <ul class="list-disc list-inside text-sm space-y-1 mt-0 mb-0">
            <li class="text-zinc-600 dark:text-zinc-300">
              Copying code from classmates or the internet without citing the
              source
            </li>
            <li class="text-zinc-600 dark:text-zinc-300">
              Submitting AI-generated code as your own work without disclosure
            </li>
            <li class="text-zinc-600 dark:text-zinc-300">
              Superficially modifying someone else's code to hide its origin
            </li>
            <li class="text-zinc-600 dark:text-zinc-300">
              Sharing solutions with other students in the same group
            </li>
          </ul>
          <p class="text-sm mt-3 mb-0">
            <span class="font-medium">{t.policies.consequences}</span>
            <span class="text-zinc-600 dark:text-zinc-300">
              {" "}{t.policies.consequencesText}
            </span>
          </p>
        </div>
      </section>

      <section>
        <div class="flex items-center gap-3 mb-4">
          <Bot class="w-5 h-5 text-zinc-500 dark:text-zinc-400 flex-shrink-0" />
          <h2 class="text-lg font-medium mt-0 mb-0">{t.policies.aiPolicy}</h2>
        </div>
        <div
          class="bg-white dark:bg-zinc-800/50 border border-zinc-200 dark:border-zinc-700 rounded p-5 space-y-4"
        >
          <p class="text-sm text-zinc-600 dark:text-zinc-300 mt-0 mb-0">
            {t.policies.aiPolicyText}
          </p>

          <div>
            <p class="text-sm font-medium text-green-700 dark:text-green-400 mb-2 mt-0">
              {t.policies.allowed}
            </p>
            <ul class="list-disc list-inside text-sm space-y-1 mt-0 mb-0">
              <li class="text-zinc-600 dark:text-zinc-300">
                Using AI to understand concepts and clarify theoretical doubts
              </li>
              <li class="text-zinc-600 dark:text-zinc-300">
                Debugging compilation errors or unexpected behavior
              </li>
              <li class="text-zinc-600 dark:text-zinc-300">
                Exploring implementation alternatives to learn
              </li>
            </ul>
          </div>

          <div>
            <p class="text-sm font-medium text-red-700 dark:text-red-400 mb-2 mt-0">
              {t.policies.notAllowed}
            </p>
            <ul class="list-disc list-inside text-sm space-y-1 mt-0 mb-0">
              <li class="text-zinc-600 dark:text-zinc-300">
                Submitting AI-generated code as your own work
              </li>
              <li class="text-zinc-600 dark:text-zinc-300">
                Using AI to solve midterm or final exam questions
              </li>
              <li class="text-zinc-600 dark:text-zinc-300">
                Delegating performance analysis or conclusions to AI
              </li>
            </ul>
          </div>

          <div class="border-t border-zinc-200 dark:border-zinc-700 pt-3">
            <p class="text-sm mt-0 mb-0">
              <span class="font-medium"
                >{t.policies.mandatoryDisclosure}</span
              >
              <span class="text-zinc-600 dark:text-zinc-300">
                {" "}{t.policies.mandatoryDisclosureText}
              </span>
            </p>
          </div>
        </div>
      </section>

      <section>
        <div class="flex items-center gap-3 mb-4">
          <Clock class="w-5 h-5 text-zinc-500 dark:text-zinc-400 flex-shrink-0" />
          <h2 class="text-lg font-medium mt-0 mb-0">
            {t.policies.lateSubmissions}
          </h2>
        </div>
        <div
          class="bg-white dark:bg-zinc-800/50 border border-zinc-200 dark:border-zinc-700 rounded p-5 space-y-3"
        >
          <div class="grid gap-3 md:grid-cols-3">
            <div
              class="border border-zinc-200 dark:border-zinc-700 rounded p-3 text-center"
            >
              <p class="text-sm font-medium mt-0 mb-1">
                1 {t.policies.dayLate}
              </p>
              <p
                class="text-2xl font-bold text-yellow-600 dark:text-yellow-400 mt-0 mb-1"
              >
                -10%
              </p>
              <p class="text-xs text-zinc-500 dark:text-zinc-400 mt-0 mb-0">
                {t.policies.ofGradeObtained}
              </p>
            </div>
            <div
              class="border border-zinc-200 dark:border-zinc-700 rounded p-3 text-center"
            >
              <p class="text-sm font-medium mt-0 mb-1">
                2 {t.policies.daysLate}
              </p>
              <p
                class="text-2xl font-bold text-orange-600 dark:text-orange-400 mt-0 mb-1"
              >
                -20%
              </p>
              <p class="text-xs text-zinc-500 dark:text-zinc-400 mt-0 mb-0">
                {t.policies.ofGradeObtained}
              </p>
            </div>
            <div
              class="border border-zinc-200 dark:border-zinc-700 rounded p-3 text-center"
            >
              <p class="text-sm font-medium mt-0 mb-1">
                3 {t.policies.daysLate}
              </p>
              <p
                class="text-2xl font-bold text-orange-700 dark:text-orange-500 mt-0 mb-1"
              >
                -30%
              </p>
              <p class="text-xs text-zinc-500 dark:text-zinc-400 mt-0 mb-0">
                {t.policies.ofGradeObtained}
              </p>
            </div>
          </div>
          <p class="text-sm text-zinc-600 dark:text-zinc-300 mt-0 mb-0">
            {t.policies.lateSubmissionText}
          </p>
        </div>
      </section>

      <section>
        <div class="flex items-center gap-3 mb-4">
          <UserCheck
            class="w-5 h-5 text-zinc-500 dark:text-zinc-400 flex-shrink-0"
          />
          <h2 class="text-lg font-medium mt-0 mb-0">{t.policies.attendance}</h2>
        </div>
        <div
          class="bg-white dark:bg-zinc-800/50 border border-zinc-200 dark:border-zinc-700 rounded p-5 space-y-3"
        >
          <p class="text-sm text-zinc-600 dark:text-zinc-300 mt-0 mb-0">
            {t.policies.attendanceText.replace("70%", "")}
            <span class="font-medium">{t.policies.minimumAttendance}</span>
            {" "}required to take exams and pass the course.
          </p>
          <ul class="list-disc list-inside text-sm space-y-1 mt-0 mb-0">
            <li class="text-zinc-600 dark:text-zinc-300">
              3 unexcused absences result in DPI status (Failed by Absence)
            </li>
            <li class="text-zinc-600 dark:text-zinc-300">
              Repeated tardiness (more than 10 minutes) counts as half an
              absence
            </li>
            <li class="text-zinc-600 dark:text-zinc-300">
              Health-related absences must be justified with medical documentation
              within 48 hours
            </li>
          </ul>
        </div>
      </section>

      <section>
        <div class="flex items-center gap-3 mb-4">
          <Heart class="w-5 h-5 text-zinc-500 dark:text-zinc-400 flex-shrink-0" />
          <h2 class="text-lg font-medium mt-0 mb-0">
            {t.policies.accommodations}
          </h2>
        </div>
        <div
          class="bg-white dark:bg-zinc-800/50 border border-zinc-200 dark:border-zinc-700 rounded p-5"
        >
          <p class="text-sm text-zinc-600 dark:text-zinc-300 mt-0 mb-0">
            {t.policies.accommodationsText}
          </p>
        </div>
      </section>
    </div>
  </div>
</BaseLayout>
