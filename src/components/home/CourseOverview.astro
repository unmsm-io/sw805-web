---
import { COURSE_CONFIG } from "../../config/course";
import { type Locale } from "../../i18n/translations";

interface Props { locale?: Locale }
const { locale = "es" } = Astro.props;

const isEn = locale === "en";

const moduleTopics = COURSE_CONFIG.modules.map((module) => ({
  ...module,
  topics: [...new Set(module.content.map((week) => week.topic))],
}));

const heading = isEn ? "Course Overview" : "Descripción del Curso";
const description = isEn
  ? "This course provides a comprehensive introduction to parallel and concurrent programming, covering the main paradigms and technologies used in modern high-performance computing."
  : "Este curso proporciona una introducción completa a la programación paralela y concurrente, cubriendo los principales paradigmas y tecnologías utilizadas en la computación de alto rendimiento moderna.";
const objectivesHeading = isEn ? "Learning Objectives" : "Objetivos de Aprendizaje";
const objectives = isEn
  ? [
      "Understand the fundamentals of parallel and concurrent programming",
      "Develop practical skills in OpenMP, MPI, and CUDA",
      "Implement efficient solutions for computational problems",
      "Analyze and optimize the performance of parallel applications",
    ]
  : [
      "Comprender los fundamentos de la programación paralela y concurrente",
      "Desarrollar habilidades prácticas en OpenMP, MPI, y CUDA",
      "Implementar soluciones eficientes para problemas computacionales",
      "Analizar y optimizar el rendimiento de aplicaciones paralelas",
    ];
const modulesHeading = isEn ? "Modules" : "Módulos";
const weeksLabel = isEn ? "Weeks" : "Semanas";
---

<section class="prose dark:prose-invert mb-0 max-w-none">
  <div class="rounded-lg p-6">
    <h2 class="text-xl font-semibold mb-4 mt-0">{heading}</h2>
    <p class="text-zinc-600 dark:text-zinc-300">{description}</p>

    <h3 class="text-lg font-semibold mt-6 mb-3">{objectivesHeading}</h3>
    <ul class="space-y-2">
      {objectives.map((obj) => <li>{obj}</li>)}
    </ul>

    <div class="mt-6">
      <h3 class="text-lg font-semibold mb-3">{modulesHeading}</h3>
      <div class="grid sm:grid-cols-2 gap-4">
        {
          moduleTopics.map((module) => (
            <div class="bg-white dark:bg-zinc-800/50 border border-zinc-200 dark:border-zinc-700 rounded p-4">
              <h4 class="font-semibold text-sm mb-2 mt-0">{module.title}</h4>
              <p class="text-sm text-zinc-500 dark:text-zinc-400 mb-0">
                {weeksLabel} {module.weeks}
              </p>
              <ul class="text-sm mt-2 mb-0 text-zinc-600 dark:text-zinc-300 space-y-1">
                {module.topics.map((topic) => (
                  <li>{topic}</li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
