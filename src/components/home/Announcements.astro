---
import { COURSE_CONFIG, type Announcement } from "../../config/course";
import { type Locale } from "../../i18n/translations";

interface Props { locale?: Locale }
const { locale = "es" } = Astro.props;
const { announcements } = COURSE_CONFIG;
const heading = locale === "en" ? "Announcements" : "Anuncios";
const dateLocale = locale === "en" ? "en-US" : "es-PE";
---

<section class="prose dark:prose-invert max-w-none">
  <div class="p-6">
    <h2 class="text-xl font-semibold mt-0 mb-0 flex items-center gap-2">
      {heading}
    </h2>
    <div class="divide-y divide-zinc-200 dark:divide-zinc-700">
      {
        announcements.map((announcement: Announcement) => (
          <div class="py-4">
            <h3 class="text-base mt-0 font-medium mb-1">
              {announcement.title}
            </h3>
            <p class="text-sm text-zinc-600 dark:text-zinc-300">
              {announcement.content}
            </p>
            <time
              datetime={announcement.date}
              class="block mt-2 text-sm text-zinc-500"
            >
              {new Date(announcement.date).toLocaleDateString(dateLocale, {
                year: "numeric",
                month: "long",
                day: "numeric",
              })}
            </time>
          </div>
        ))
      }
    </div>
  </div>
</section>
